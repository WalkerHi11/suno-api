# For more information, please see the README.md
SUNO_COOKIE=
TWOCAPTCHA_KEY= # Obtain from 2captcha.com
BROWSER=chromium # `chromium` or `firefox`, although `chromium` is highly recommended
BROWSER_GHOST_CURSOR=false
BROWSER_LOCALE=en
BROWSER_HEADLESS=true
CAPTCHA_TOKEN_TIMEOUT_MS=180000 # Max time to wait for hCaptcha token (ms)
SUNO_MAX_CONCURRENT_CAPTCHAS=1 # Limit concurrent browser/captcha sessions
SUNO_MAX_QUEUED_CAPTCHAS=20 # Max queued captcha waiters before rejecting
SUNO_CAPTCHA_ACQUIRE_TIMEOUT_MS=240000 # Max time to wait for captcha capacity (ms)
